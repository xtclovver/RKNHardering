<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sectionRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_checker_section_collapsed">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/sectionHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <View
            android:id="@+id/sectionStatusDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_status_green" />

        <FrameLayout
            android:id="@+id/sectionIconContainer"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_checker_icon_token">

            <ImageView
                android:id="@+id/sectionIcon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                app:tint="?android:attr/textColorSecondary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/sectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/sectionSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sectionMasterSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <ImageView
            android:id="@+id/sectionChevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_chevron_right"
            android:importantForAccessibility="no"
            app:tint="?android:attr/textColorSecondary" />
    </LinearLayout>

    <!-- Divider between header and body (only visible when expanded) -->
    <View
        android:id="@+id/sectionDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_outline_soft"
        android:visibility="gone" />

    <!-- Body container — body content is inflated dynamically -->
    <FrameLayout
        android:id="@+id/sectionBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="4dp"
        android:paddingBottom="14dp"
        android:visibility="gone" />

    <!-- Disabled note shown under body when section is masters-off -->
    <TextView
        android:id="@+id/sectionDisabledNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_disabled_note"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center"
        android:text="@string/checker_section_disabled_note"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="11sp"
        android:textStyle="italic"
        android:visibility="gone" />

</LinearLayout>
