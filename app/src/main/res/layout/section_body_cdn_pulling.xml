<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/settings_custom_check_timeout_ms">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editCdnTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="10000" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchCdnBuiltinTargets"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings_custom_check_cdn_builtin_targets"
        android:checked="true" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchCdnMeduza"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/settings_custom_check_cdn_meduza"
        android:checked="true" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchCdnRutracker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/settings_custom_check_cdn_rutracker"
        android:checked="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/inline_editor_custom_targets"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />

    <LinearLayout
        android:id="@+id/containerCdnEndpoints"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCdnEndpoint"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_custom_check_add_endpoint"
        app:icon="@drawable/ic_add_circle" />

    <FrameLayout
        android:id="@+id/inlineEditorSlotCdn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
