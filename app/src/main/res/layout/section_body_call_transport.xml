<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/settings_custom_check_timeout_ms">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editCallTransportTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="5000" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchCallTransportBuiltinGlobalStun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings_custom_check_call_builtin_global_stun"
        android:checked="true" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchCallTransportBuiltinRuStun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/settings_custom_check_call_builtin_ru_stun"
        android:checked="true" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchCallTransportMtproto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/settings_custom_check_call_mtproto"
        android:checked="true" />

    <LinearLayout
        android:id="@+id/containerStunServers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddStunServer"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_custom_check_add_stun_server"
        app:icon="@drawable/ic_add_circle" />

    <FrameLayout
        android:id="@+id/inlineEditorSlotStun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
