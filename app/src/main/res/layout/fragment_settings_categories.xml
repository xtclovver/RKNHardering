<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="24dp">

        <TextView
            style="@style/SettingsGroupLabel"
            android:text="@string/settings_group_checks" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsGroupCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/rowSplitTunnel"
                    layout="@layout/view_settings_row" />

                <View style="@style/SettingsRowDivider" />

                <include
                    android:id="@+id/rowNetwork"
                    layout="@layout/view_settings_row" />

                <View style="@style/SettingsRowDivider" />

                <include
                    android:id="@+id/rowDns"
                    layout="@layout/view_settings_row" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/SettingsGroupLabel"
            android:text="@string/settings_group_app" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsGroupCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/rowPrivacy"
                    layout="@layout/view_settings_row" />

                <View style="@style/SettingsRowDivider" />

                <include
                    android:id="@+id/rowAppearance"
                    layout="@layout/view_settings_row" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/SettingsGroupLabel"
            android:text="@string/settings_group_info" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsGroupCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/rowAbout"
                    layout="@layout/view_settings_row" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
