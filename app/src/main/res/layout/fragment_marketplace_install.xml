<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:id="@+id/installHeaderIconWrap"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_marketplace_avatar">

            <ImageView
                android:id="@+id/installHeaderIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_verified_blue"
                android:importantForAccessibility="no"
                app:tint="#FFFFFFFF" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/installTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/installSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/installBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp" />

    <!-- URL warning block (unverified only) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/installUrlBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="240dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_warning_url_block"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/installUrlList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp" />
    </androidx.core.widget.NestedScrollView>

    <!-- Footer buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="18dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/installCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/security_warning_cancel"
            app:cornerRadius="100dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/installConfirm"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/marketplace_action_install"
            app:cornerRadius="100dp" />
    </LinearLayout>
</LinearLayout>
