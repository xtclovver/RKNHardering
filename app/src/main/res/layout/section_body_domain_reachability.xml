<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_custom_check_section_domain_reachability_desc"
        android:textColor="@color/md_on_surface_variant"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/containerReachabilityDomains"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddReachabilityDomain"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_custom_check_add_reachability_domain"
        app:icon="@drawable/ic_add_circle" />

    <FrameLayout
        android:id="@+id/inlineEditorSlotDomainReachability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
